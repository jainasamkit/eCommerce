{
  "name": "ecommerce-microservices",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:shared-http": "cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-http\\tsconfig.json",
    "build:shared-auth": "cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-auth\\tsconfig.json",
    "build:shared-database": "cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-database\\tsconfig.json",
    "build:shared-messaging": "cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-messaging\\tsconfig.json",
    "build:shared": "cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-http\\tsconfig.json && cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-auth\\tsconfig.json && cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-database\\tsconfig.json && cmd /c node_modules\\.bin\\tsc.cmd -p packages\\shared-messaging\\tsconfig.json"
  },
  "dependencies": {
    "amqplib": "^1.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  }
}
