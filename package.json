{
  "name": "ecommerce-microservices",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:shared-http": "tsc -p packages/shared-http/tsconfig.json",
    "build:shared-auth": "tsc -p packages/shared-auth/tsconfig.json",
    "build:shared-database": "tsc -p packages/shared-database/tsconfig.json",
    "build:shared-messaging": "tsc -p packages/shared-messaging/tsconfig.json",
    "build:shared": "npm run build:shared-http && npm run build:shared-auth && npm run build:shared-database && npm run build:shared-messaging"
  },
  "dependencies": {
    "amqplib": "^1.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  }
}
